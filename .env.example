# ================================
# RESEND API KEY
# ================================
# Obtén tu API key en: https://resend.com/api-keys
# 1. Crea una cuenta en resend.com
# 2. Ve a API Keys
# 3. Crea una nueva key
# 4. Copia la key aquí

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ================================
# EMAIL DE DESTINO (opcional)
# ================================
# El email donde recibirás los mensajes de contacto
# Por defecto está configurado en el código

CONTACT_EMAIL=contacto@solucionesintegralesjs.com

# ================================
# BASE DE DATOS LOCAL
# ================================

LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/soluciones_integrales_local

# ================================
# STORAGE LOCAL OPCIONAL (MinIO)
# ================================
# Para usar uploads locales en vez de Supabase Storage

STORAGE_PROVIDER=supabase
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=images
MINIO_PUBLIC_URL=http://localhost:9000

# ================================
# RESEND API KEY
# ================================
# Obten tu API key en: https://resend.com/api-keys

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ================================
# EMAIL DE DESTINO (opcional)
# ================================

CONTACT_EMAIL=contacto@solucionesintegralesjs.com

# ================================
# ADMIN CMS (REQUIRED)
# ================================

ADMIN_USERNAME=admin
ADMIN_PASSWORD=112358
ADMIN_SECRET=cambia-esto-en-produccion

# ================================
# DATABASE
# ================================
# Production (Neon or any PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Local development (optional)
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/soluciones_integrales_local

# ================================
# STORAGE (R2 RECOMMENDED)
# ================================
# Use r2 for Cloudflare R2 (or any S3-compatible endpoint)

STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_PORT=443
R2_USE_SSL=true
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=soluciones-integrales-bucket
R2_PUBLIC_URL=
R2_PATH_STYLE=false

# ================================
# SUPABASE STORAGE (OPTIONAL)
# ================================
# Only required if STORAGE_PROVIDER=supabase

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
